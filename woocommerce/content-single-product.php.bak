                            <?php echo wp_get_attachment_image( $img_id, 'full', false, array( 'class' => 'w-full h-auto object-contain mix-blend-multiply drop-shadow-sm' ) ); ?>
                        </div>
                    <?php endforeach; ?>
                <?php else: ?>
                    <div class="editorial-gallery-item">
                        <span class="text-gray-400 text-sm tracking-widest uppercase">No Image Available</span>
                    </div>
                <?php endif; ?>
            </div>
        </div>

        <!-- Right Side: Details Box (Span 4) -->
        <div class="lg:col-span-4 flex flex-col justify-center py-4">
            <!-- Title -->
            <h1 class="text-[1.35rem] uppercase font-bold text-[#111] leading-snug tracking-wide mb-3">
                <?php the_title(); ?>
            </h1>
            
            <!-- Price -->
            <div class="mb-8">
                <div class="text-[1.05rem] font-semibold text-[#111] tracking-tight">
                    <?php echo $product->get_price_html(); ?>
                </div>
            </div>

            <!-- Add to Cart Form -->
            <div class="mb-4">
                <?php woocommerce_template_single_add_to_cart(); ?>
            </div>
            
            <!-- Wishlist Area -->
            <div class="mt-6 flex items-center gap-3 text-[#111] cursor-pointer hover:opacity-70 transition-opacity w-max text-xs font-semibold uppercase tracking-wider">
                <!-- Solid minimal heart icon matching reference -->
                <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path></svg>
                Add to wishlist
            </div>
            
            <!-- Extra Product Meta -->
            <div class="product_meta tracking-wide font-medium">
                <?php if ( wc_product_sku_enabled() && ( $product->get_sku() || $product->is_type( 'variable' ) ) ) : ?>
                    <span class="sku_wrapper mb-1">SKU: <span class="sku font-normal"><?php echo ( $sku = $product->get_sku() ) ? $sku : esc_html__( 'N/A', 'woocommerce' ); ?></span></span>
                <?php endif; ?>
                <?php echo wc_get_product_category_list( $product->get_id(), ', ', '<span class="posted_in mb-1">Category: <span class="font-normal">', '</span></span>' ); ?>
                <?php echo wc_get_product_tag_list( $product->get_id(), ', ', '<span class="tagged_as">Tags: <span class="font-normal">', '</span></span>' ); ?>
            </div>
        </div>

    </div>

    <!-- THE EDITORIAL DESCRIPTION FLOW (Replaces Tabs) -->
    <div class="border-t border-[#eee] mt-12 w-full">
        <!-- We wrap the tab output in our editorial prose class -->
        <div class="editorial-prose">
            <?php do_action( 'woocommerce_after_single_product_summary' ); ?>
        </div>
    </div>

</div>

<?php do_action( 'woocommerce_after_single_product' ); ?>

<script>
document.addEventListener('DOMContentLoaded', function() {
    
    // 1. Swatches and Custom Add to Cart Setup
    const variationForms = document.querySelectorAll('.variations_form');
    
    variationForms.forEach(form => {
        const selects = form.querySelectorAll('table.variations select');
        
        // Custom Quantity Buttons (injecting layout)
        const qtyWrap = form.querySelector('.quantity');
        if (qtyWrap && !qtyWrap.querySelector('.qty-btn.minus')) {
            const qtyInput = qtyWrap.querySelector('input.qty');
            
            const minusBtn = document.createElement('button');
            minusBtn.type = 'button'; minusBtn.className = 'qty-btn minus'; minusBtn.textContent = '-';
            
            const plusBtn = document.createElement('button');
            plusBtn.type = 'button'; plusBtn.className = 'qty-btn plus'; plusBtn.textContent = '+';
            
            qtyWrap.insertBefore(minusBtn, qtyInput);
            qtyWrap.appendChild(plusBtn);
            
            minusBtn.addEventListener('click', () => {
                let val = parseInt(qtyInput.value || 1);
                if(val > 1) {
                    qtyInput.value = val - 1;
                    jQuery(qtyInput).trigger('change');
                }
            });
            
            plusBtn.addEventListener('click', () => {
                let val = parseInt(qtyInput.value || 1);
                let max = parseInt(qtyInput.getAttribute('max') || 9999);
                if(val < max) {
                    qtyInput.value = val + 1;
                    jQuery(qtyInput).trigger('change');
                }
            });
        }

        // Custom Swatches
        selects.forEach(select => {
            const parentTd = select.closest('td.value');
            if(!parentTd) return;
            
            const wrapper = document.createElement('div');
            wrapper.className = 'swatches-wrapper';
            
            // Look for color hints for circles vs text
            const isColor = select.getAttribute('name').toLowerCase().includes('color');
            
            Array.from(select.options).forEach(opt => {
                if(!opt.value) return; 
                
                const btn = document.createElement('div');
                
                if(isColor) {
                    // Try to guess a color style or just show a colored dot beside text
                    btn.className = 'size-swatch flex items-center gap-2';
                    btn.innerHTML = `<span style="width:10px;height:10px;border-radius:50%;background:${opt.value.toLowerCase()};display:inline-block;border:1px solid #ccc;"></span> ${opt.text}`;
                } else {
                    btn.className = 'size-swatch';
                    btn.textContent = opt.text;
                }
                
                btn.addEventListener('click', () => {
                    Array.from(wrapper.children).forEach(c => c.classList.remove('active'));
                    btn.classList.add('active');
                    
                    select.value = opt.value;
                    jQuery(select).trigger('change');
                });
                
                wrapper.appendChild(btn);
            });
            
            parentTd.appendChild(wrapper);
        });
        
        // Add to cart state logic
        const addToCartBtn = form.querySelector('.single_add_to_cart_button');
        
        jQuery(form).on('found_variation', function(event, variation) {
            if(variation.is_purchasable && variation.is_in_stock) {
                addToCartBtn.classList.add('active');
                if(addToCartBtn.tagName.toLowerCase() === 'button') {
                    addToCartBtn.disabled = false;
                }
            } else {
                addToCartBtn.classList.remove('active');
                if(addToCartBtn.tagName.toLowerCase() === 'button') {
                    addToCartBtn.disabled = true;
                }
            }
        });
        
        jQuery(form).on('reset_image reset_data', function() {
            addToCartBtn.classList.remove('active');
            if(addToCartBtn.tagName.toLowerCase() === 'button') {
                addToCartBtn.disabled = true;
            }
            form.querySelectorAll('.size-swatch').forEach(c => c.classList.remove('active'));
        });
        
        // Initial button state
        if(addToCartBtn && addToCartBtn.tagName.toLowerCase() === 'button') {
            addToCartBtn.disabled = true;
        }
    });

});
</script>
