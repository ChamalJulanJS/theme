<style>
/* EDITORIAL / MINIMALIST PRODUCT LAYOUT */
body { background-color: #ffffff; color: #111; font-family: 'Inter', sans-serif; }

/* Swatches - Minimalist */
.variations-table { width: 100%; margin-bottom: 2rem; }
.woocommerce div.product form.cart table.variations select { display: none !important; }
.woocommerce div.product form.cart table.variations th { display: none; } /* Hide labels for ultra-minimalist look */
.woocommerce div.product form.cart table.variations td.label { padding:0; margin:0; }

.swatches-wrapper { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.size-swatch { 
    display: inline-flex; align-items: center; justify-content: center; 
    min-width: 3rem; height: 2.25rem; border: 1px solid #d4d4d4; background: #fff; 
    color: #555; cursor: pointer; transition: all 0.2s; font-size: 0.85rem; padding: 0 0.75rem;
}
.size-swatch:hover { border-color: #111; color: #111; }
.size-swatch.active { border-color: #111; box-shadow: inset 0 0 0 1px #111; color: #111; font-weight: 500;}

/* Action Row (Quantity + Add to Cart) */
.woocommerce-variation-add-to-cart {
    display: flex; gap: 0.5rem; align-items: stretch; margin-top: 2rem; flex-wrap: wrap;
}
.quantity {
    display: flex; border: 1px solid #d4d4d4; align-items: center; height: 3rem; background: #fff; max-width: 140px;
}
.quantity input[type="number"] {
    width: 50px; text-align: center; border: none; font-weight: 600; font-size: 0.95rem; -moz-appearance: textfield; padding: 0; outline: none; background: transparent; color: #111;
}
.quantity input[type="number"]::-webkit-outer-spin-button,
.quantity input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none; margin: 0;
}
.qty-btn { 
    padding: 0 1rem; font-size: 1.1rem; font-weight: 500; cursor: pointer; color: #111; background: none; border: none; outline: none; transition: background 0.2s; height: 100%;
}
.qty-btn:hover { background-color: #f5f5f5; }

/* Cart Button - Specific solid gray matching reference */
.single_add_to_cart_button {
    flex: 1; background-color: #8c8c8c; color: #fff; border: none; font-weight: 700; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; cursor: not-allowed; transition: background 0.2s; min-width: 200px; height: 3rem; display: flex; align-items: center; justify-content: center;
}
.single_add_to_cart_button.active {
    background-color: #8c8c8c; cursor: pointer; /* Stays gray but clickable */
}
.single_add_to_cart_button.active:hover { background-color: #666; }

/* Horizontal Gallery Layout */
.editorial-gallery {
    display: flex; overflow-x: auto; scroll-snap-type: x mandatory; gap: 0; border: 1px solid #f0f0f0; background: #fcfcfc;
}
.editorial-gallery::-webkit-scrollbar { height: 4px; }
.editorial-gallery::-webkit-scrollbar-thumb { background: #ddd; }
.editorial-gallery-item {
    flex: 0 0 100%; scroll-snap-align: start; padding: 2rem; display: flex; align-items: center; justify-content: center; border-right: 1px solid #f0f0f0;
}
@media(min-width: 768px) {
    /* Show 4 side by side seamlessly on larger screens to match image 1 */
    .editorial-gallery-item { flex: 0 0 25%; padding: 1rem; }
}
.editorial-gallery-item img { max-width: 100%; height: auto; object-fit: contain; mix-blend-multiply: true; }

/* Meta */
.product_meta { margin-top: 2rem; font-size: 0.8rem; color: #777; line-height: 1.8; padding-top: 2rem; border-top: 1px solid #f5f5f5; }
.product_meta span { display: block; }
.product_meta a { color: #111; text-decoration: none; }
.product_meta a:hover { text-decoration: underline; }

/* NO TABS - Continuous Editorial Flow */
.woocommerce-tabs ul.tabs { display: none !important; }
.woocommerce-tabs .panel { display: block !important; border: none !important; box-shadow: none !important; background: transparent !important; padding: 4rem 0 !important; }
.woocommerce-tabs .panel h2 { display: none; }

/* Editorial Prose for Description */
.editorial-prose {
    max-width: 100%; font-size: 0.95rem; line-height: 1.8; color: #333; margin: 0 auto;
}
.editorial-prose img { width: 100%; height: auto; margin-bottom: 2rem; }
/* Simulating a staggered masonry layout if user adds images and paragraphs */
@media(min-width: 1024px) {
    .editorial-prose {
        column-count: 2; column-gap: 4rem; column-fill: balance;
    }
    .editorial-prose p { break-inside: avoid; margin-bottom: 2rem; }
    .editorial-prose img { break-inside: avoid; width: 100%; margin-bottom: 2rem; }
}

.reset_variations { display: none !important; }
</style>

<div id="product-<?php the_ID(); ?>" <?php wc_product_class( 'pt-16 pb-24 max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12', $product ); ?>>

    <!-- THE PRODUCT HEAD PANEL -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 mb-20">
        
        <!-- Left Side: Horizontal Strip Gallery (Span 8) -->
        <div class="lg:col-span-8 flex items-center bg-[#f9f9f9]">
